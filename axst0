local speedValue = Instance.new("TextLabel")
speedValue.Parent = movementTab
speedValue.Size = UDim2.new(0, 50, 0, 30)
speedValue.Position = UDim2.new(0, 230, 0, 20)
speedValue.BackgroundTransparency = 1
speedValue.Text = "1.0"
speedValue.TextColor3 = Color3.new(0, 0.8, 1)
speedValue.TextScaled = true
speedValue.Font = Enum.Font.ScienceFuture

local speedMultiplier = 1.0
local defaultWalkSpeed = humanoid.WalkSpeed

local function updateSpeed()
    humanoid.WalkSpeed = defaultWalkSpeed * speedMultiplier
end

local isDraggingSpeed = false
speedSlider.MouseButton1Down:Connect(function()
    isDraggingSpeed = true
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
    if isDraggingSpeed and input.UserInputType == Enum.UserInputType.MouseMovement then
        local relativeX = input.Position.X - speedSlider.AbsolutePosition.X
        relativeX = math.max(0, math.min(relativeX, speedSlider.AbsoluteSize.X))
        speedMultiplier = 0.5 + (relativeX / speedSlider.AbsoluteSize.X) * 4.5 -- 0.5 bis 5.0
        speedValue.Text = string.format("%.1f", speedMultiplier)
        updateSpeed()
    end
end)

game:GetService("UserInputService").InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDraggingSpeed = false
    end
end)

-- Fly Button
local flyButton = Instance.new("TextButton")
flyButton.Parent = movementTab
flyButton.Size = UDim2.new(0, 200, 0, 40)
flyButton.Position = UDim2.new(0, 20, 0, 80)
flyButton.BackgroundColor3 = Color3.new(0, 0.3, 0.8)
flyButton.BorderSizePixel = 0
flyButton.Text = "FLY: OFF"
flyButton.TextColor3 = Color3.new(0, 0.8, 1)
flyButton.TextScaled = true
flyButton.Font = Enum.Font.ScienceFuture

local flyEnabled = false
local flySpeed = 50
local bv, bg

local function toggleFly()
    flyEnabled = not flyEnabled
    flyButton.Text = "FLY: " .. (flyEnabled and "ON" or "OFF")
    
    if flyEnabled then
        bv = Instance.new("BodyVelocity")
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.Parent = humanoid.RootPart
        
        bg = Instance.new("BodyGyro")
        bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bg.P = 10000
        bg.Parent = humanoid.RootPart
    else
        if bv then bv:Destroy() end
        if bg then bg:Destroy() end
    end
end

flyButton.MouseButton1Click:Connect(toggleFly)

-- Fly Steuerung
game:GetService("UserInputService").InputBegan:Connect(function(input)
    if flyEnabled then
        if input.KeyCode == Enum.KeyCode.W then
            bv.Velocity = humanoid.RootPart.CFrame.lookVector * flySpeed
        elseif input.KeyCode == Enum.KeyCode.S then
            bv.Velocity = humanoid.RootPart.CFrame.lookVector * -flySpeed
        elseif input.KeyCode == Enum.KeyCode.A then
            bv.Velocity = humanoid.RootPart.CFrame.RightVector * -flySpeed
        elseif input.KeyCode == Enum.KeyCode.D then
            bv.Velocity = humanoid.RootPart.CFrame.RightVector * flySpeed
        elseif input.KeyCode == Enum.KeyCode.Space then
            bv.Velocity = Vector3.new(0, flySpeed, 0)
        elseif input.KeyCode == Enum.KeyCode.LeftShift then
            bv.Velocity = Vector3.new(0, -flySpeed, 0)
        end
    end
end)


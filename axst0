espButton.Text = "ESP: OFF"
espButton.TextColor3 = Color3.new(0, 0.8, 1)
espButton.TextScaled = true
espButton.Font = Enum.Font.ScienceFuture

local espEnabled = false
local espConnections = {}

local function createEspHighlight(model, color)
    local highlight = Instance.new("Highlight")
    highlight.Parent = model
    highlight.FillColor = color
    highlight.FillTransparency = 0.3
    highlight.OutlineColor = color
    return highlight
end

local function toggleEsp()
    espEnabled = not espEnabled
    espButton.Text = "ESP: " .. (espEnabled and "ON" or "OFF")
    
    if espEnabled then
        -- Spieler-ESP
        for _, plr in pairs(game.Players:GetPlayers()) do
            if plr ~= player and plr.Character then
                local highlight = createEspHighlight(plr.Character, Color3.new(0, 0.8, 1))
                table.insert(espConnections, highlight)
            end
        end
        
        -- Animatronik-ESP (rot)
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj.Name:lower():find("animatron") or obj.Name:lower():find("monster") or obj.Name:lower():find("enemy") then
                local highlight = createEspHighlight(obj, Color3.new(1, 0, 0))
                table.insert(espConnections, highlight)
            end
        end
        
        -- Neue Spieler erkennen
        game.Players.PlayerAdded:Connect(function(plr)
            if espEnabled and plr ~= player and plr.Character then
                local highlight = createEspHighlight(plr.Character, Color3.new(0, 0.8, 1))
                table.insert(espConnections, highlight)
            end
        end)
    else
        -- ESP entfernen
        for _, connection in pairs(espConnections) do
            if connection and connection.Parent then
                connection:Destroy()
            end
        end
        espConnections = {}
    end
end

espButton.MouseButton1Click:Connect(toggleEsp)

